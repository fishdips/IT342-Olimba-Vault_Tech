<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_vault_card"
    android:elevation="4dp"
    android:clipToOutline="true">

    <View
        android:id="@+id/card_accent_bar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="#0066b1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_vault_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Family Documents"
                android:textColor="#ffe1ba"
                android:fontFamily="serif"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_secure"
                app:tint="#4a7a9b" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_vault_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Created: May 9, 2026"
            android:textColor="#4a7a9b"
            android:textSize="12sp"
            android:layout_marginTop="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">

            <ProgressBar
                android:id="@+id/pb_deadman"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_weight="1"
                android:progress="75"
                android:progressTint="#0066b1"
                android:backgroundTint="#02243e" />

            <TextView
                android:id="@+id/tv_days_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="30 Days"
                android:textColor="#6a9dbf"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>